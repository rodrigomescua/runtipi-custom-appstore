{
  "$schema": "https://schemas.runtipi.io/v2/app-info.json",
  "name": "Authentik",
  "id": "authentik",
  "available": true,
  "short_desc": "The authentication glue you need.",
  "author": "Authentik Security Inc.",
  "port": 9000,
  "https": true,
  "categories": [
    "security"
  ],
  "description": "authentik is an open-source Identity Provider that emphasizes flexibility and versatility, with support for a wide set of protocols.",
  "min_tipi_version": "v4.5.0",
  "tipi_version": 25,
  "version": "2026.5.3",
  "source": "https://github.com/goauthentik/authentik",
  "website": "https://goauthentik.io",
  "exposable": true,
  "supported_architectures": [
    "arm64",
    "amd64"
  ],
  "form_fields": [
    {
      "type": "random",
      "label": "DB Password",
      "min": 40,
      "env_variable": "AUTHENTIK_DB_PASSWORD",
      "required": true
    },
    {
      "type": "random",
      "label": "Secret Key",
      "min": 60,
      "max": 60,
      "env_variable": "AUTHENTIK_SECRET_KEY",
      "required": true
    },
    {
      "type": "boolean",
      "label": "Disable Startup Analytics",
      "default": true,
      "env_variable": "AUTHENTIK_DISABLE_STARTUP_ANALYTICS",
      "required": false
    },
    {
      "type": "boolean",
      "label": "Disable Update Check",
      "default": false,
      "env_variable": "AUTHENTIK_DISABLE_UPDATE_CHECK",
      "required": false
    },
    {
      "type": "boolean",
      "label": "Error Reporting",
      "default": false,
      "env_variable": "AUTHENTIK_ERROR_REPORTING__ENABLED",
      "required": false
    }
  ],
  "created_at": 1747988183970,
  "updated_at": 1781884692773,
  "dynamic_config": true
}