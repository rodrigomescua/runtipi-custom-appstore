{
  "$schema": "https://schemas.runtipi.io/v2/dynamic-compose.json",
  "schemaVersion": 2,
  "services": [
    {
      "name": "wallabag_db",
      "image": "mariadb:lts",
      "environment": [
        {
          "key": "MARIADB_ROOT_PASSWORD",
          "value": "wallaroot"
        },
        {
          "key": "MARIADB_USER",
          "value": "wallabag"
        },
        {
          "key": "MARIADB_DATABASE",
          "value": "wallabag"
        },
        {
          "key": "MARIADB_PASSWORD",
          "value": "wallabag"
        },
        {
          "key": "TZ",
          "value": "${TZ}"
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/mysql",
          "containerPath": "/var/lib/mysql"
        }
      ],
      "healthCheck": {
        "test": "healthcheck.sh --connect --innodb_initialized",
        "interval": "30s",
        "timeout": "10s",
        "retries": 5
      }
    },
    {
      "name": "wallabag_redis",
      "image": "redis:alpine",
      "healthCheck": {
        "test": "redis-cli ping",
        "interval": "20s",
        "timeout": "3s",
        "retries": 5
      }
    },
    {
      "name": "wallabag",
      "image": "wallabag/wallabag:2.6.14",
      "isMain": true,
      "internalPort": 80,
      "environment": [
        {
          "key": "MYSQL_ROOT_PASSWORD",
          "value": "wallaroot"
        },
        {
          "key": "SYMFONY__ENV__DATABASE_DRIVER",
          "value": "pdo_mysql"
        },
        {
          "key": "SYMFONY__ENV__DATABASE_HOST",
          "value": "wallabag_db"
        },
        {
          "key": "SYMFONY__ENV__DATABASE_PORT",
          "value": "3306"
        },
        {
          "key": "SYMFONY__ENV__DATABASE_NAME",
          "value": "wallabag"
        },
        {
          "key": "SYMFONY__ENV__DATABASE_USER",
          "value": "wallabag"
        },
        {
          "key": "SYMFONY__ENV__DATABASE_PASSWORD",
          "value": "wallabag"
        },
        {
          "key": "SYMFONY__ENV__DATABASE_CHARSET",
          "value": "utf8mb4"
        },
        {
          "key": "SYMFONY__ENV__DATABASE_TABLE_PREFIX",
          "value": "wallabag_"
        },
        {
          "key": "SYMFONY__ENV__DOMAIN_NAME",
          "value": "https://${APP_DOMAIN}"
        },
        {
          "key": "SYMFONY__ENV__SERVER_NAME",
          "value": "Wallabag"
        },
        {
          "key": "SYMFONY__ENV__FOSUSER_REGISTRATION",
          "value": "${ALLOW_USER_REGISTRATION}"
        },
        {
          "key": "SYMFONY__ENV__REDIS_SCHEME",
          "value": "tcp"
        },
        {
          "key": "SYMFONY__ENV__REDIS_HOST",
          "value": "wallabag_redis"
        },
        {
          "key": "SYMFONY__ENV__REDIS_PORT",
          "value": "6379"
        },
        {
          "key": "TZ",
          "value": "${TZ}"
        },
        {
          "key": "POPULATE_DATABASE",
          "value": "false"
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/data",
          "containerPath": "/var/www/wallabag/data"
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/images",
          "containerPath": "/var/www/wallabag/web/assets/images"
        }
      ],
      "dependsOn": {
        "wallabag_db": {
          "condition": "service_healthy"
        },
        "wallabag_redis": {
          "condition": "service_healthy"
        }
      }
    }
  ]
}
