{
  "version": "2.0",
  "description": "Canonical Runtipi app-store rules for Codex and other local tooling.",
  "lastUpdated": "2026-07-08",
  "rules": {
    "appStructure": {
      "requiredFiles": [
        "config.json",
        "docker-compose.yml",
        "metadata/description.md",
        "metadata/logo.jpg"
      ],
      "forbiddenFiles": [
        "docker-compose.json",
        "docker-compose.yaml"
      ],
      "idFormat": {
        "description": "The app id must match the folder name under apps/.",
        "example": "apps/linkding/config.json must use id: linkding"
      }
    },
    "configJson": {
      "mandatoryFields": [
        "$schema",
        "name",
        "id",
        "available",
        "short_desc",
        "author",
        "port",
        "categories",
        "description",
        "tipi_version",
        "version",
        "source",
        "exposable",
        "dynamic_config",
        "supported_architectures",
        "created_at",
        "updated_at",
        "form_fields"
      ],
      "portingRules": {
        "range": "8800-8999",
        "verifyBeforeUse": true
      },
      "versionRules": {
        "versionMustMatchImageTag": true,
        "noLatestTag": true,
        "registryMustBeVerified": true
      }
    },
    "dockerCompose": {
      "schemaVersion": 2,
      "fileName": "docker-compose.yml",
      "format": "yaml",
      "rootVersion": "3",
      "serviceShape": "services is an object keyed by service name",
      "mainServiceRule": "Exactly one service may set x-runtipi.is_main to true",
      "dependencyRule": "depends_on must use object form with service_healthy or service_started conditions",
      "volumeRule": "Use ${APP_DATA_DIR}/data/<last-segment-of-container-path>",
      "portsRule": "Do not add a ports block",
      "tagRule": "The main service image tag must match config.json.version exactly"
    },
    "metadata": {
      "descriptionFile": "metadata/description.md",
      "logoFile": "metadata/logo.jpg",
      "logoFormat": "512x512 JPG",
      "logoGuidance": "Use the official logo first; keep margins; avoid rounded corners"
    },
    "formFields": {
      "allowedTypes": [
        "text",
        "password",
        "email",
        "number",
        "fqdn",
        "ip",
        "fqdnip",
        "random",
        "boolean"
      ],
      "databaseCredentialsRule": "Do not ask for database credentials in form_fields."
    },
    "categories": [
      "featured",
      "utilities",
      "automation",
      "network",
      "media",
      "development",
      "social",
      "security",
      "photography",
      "books",
      "data",
      "music",
      "finance",
      "gaming",
      "ai"
    ],
    "validation": {
      "primaryCommand": "bun test",
      "versionUpdateCommand": "bun scripts/update-config.ts apps/<app-name>/docker-compose.yml"
    }
  }
}
