{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": false,
  "dependencyDashboard": false,
  "prHourlyLimit": 20,
  "extends": [
    "config:recommended"
  ],
  "addLabels": [
    "renovate"
  ],

  "automergeStrategy": "rebase",
  "prCreation": "immediate",
  "rebaseWhen": "conflicted",

  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "major",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": false
    },
    {
      "matchDepTypes": [
        "devDependencies"
      ],
      "automerge": false
    },
    {
      "matchPackageNames": [
        "mariadb",
        "mysql",
        "mongo",
        "mongodb",
        "postgres",
        "postgis/postgis",
        "redis",
        "rabbitmq",
        "milvusdb/milvus",
        "minio/minio",
        "quay.io/coreos/etcd"
      ],
      "enabled": false
    },
    {
      "enabled": false,
      "matchPackageNames": [
        "/.*-etcd$/",
        "/.*-minio$/",
        "/.*-redis$/"
      ]
    },
    {
      "description": "Group all updates for the same app into a single PR",
      "matchFileNames": [
        "apps/**"
      ],
      "groupName": "{{parentDir}}"
    },
    {
      "description": "Automerge major, minor, patch, and digest updates for trusted app images",
      "matchFileNames": [
        "apps/dockhand/docker-compose.yml",
        "apps/murkpyrss/docker-compose.yml",
        "apps/murkrss/docker-compose.yml",
        "apps/pricebuddy/docker-compose.yml",
        "apps/razor-finance/docker-compose.yml",
        "apps/razorstash/docker-compose.yml",
        "apps/rustavoid/docker-compose.yml",
        "apps/rustpnews/docker-compose.yml",
        "apps/ruststash/docker-compose.yml",
        "apps/tuliprox/docker-compose.yml"
      ],
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "digest"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Allow dev-* tags for m3u-editor",
      "matchPackageNames": [
        "sparkison/m3u-editor"
      ],
      "versioning": "regex:^dev-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$",
      "pinDigests": false
    },
    {
      "description": "Allow alpha versions for Sure",
      "matchPackageNames": [
        "ghcr.io/we-promise/sure"
      ],
      "ignoreUnstable": false
    },
    {
      "description": "Do not update the renovate workflow itself to keep node-version: 22",
      "matchFileNames": [
        ".github/workflows/renovate.yml"
      ],
      "enabled": false
    }
  ],
  "postUpgradeTasks": {
    "commands": [
      "bun install",
      "bun ./scripts/update-config.ts {{packageFile}} {{newVersion}} {{packageName}}",
      "bun run test"
    ],
    "fileFilters": [
      "apps/**/config.json",
      "apps/**/docker-compose.yml"
    ],
    "executionMode": "branch"
  }
}
